<template>
  <div class="keyboard-page {{screentype === 'rect' ? 'keyboard-page-rect' : 'keyboard-page-round'}}" show="{{!hide}}">
    <div class="keyboard-container {{screentype === 'rect' ? 'keyboard-container-rect' : 'keyboard-container-round'}}">
      
      <div class="keyboard-row">
        <text 
          class="key-item" 
          for="{{char in activeRow1}}" 
          @click="pressKey(char)">
          {{char}}
        </text>
      </div>

      <div class="keyboard-row">
        <div class="row2-spacer"></div>
        <text 
          class="key-item" 
          for="{{char in activeRow2}}" 
          @click="pressKey(char)">
          {{char}}
        </text>
        <div class="row2-spacer"></div>
      </div>

      <div class="keyboard-row">
        <text 
          if="{{!numFlag}}"
          class="key-item key-item-special key-item-shift {{upperFlag ? 'key-item-shift-active' : ''}}" 
          @click="toggleShift">
          Shift
        </text>
        <text 
          if="{{numFlag}}"
          class="key-item key-item-special key-item-sympage" 
          @click="toggleSymbolPage">
          {{symPageFlag ? '1/2' : '2/2'}}
        </text>

        <text 
          class="key-item" 
          for="{{char in activeRow3}}" 
          @click="pressKey(char)">
          {{char}}
        </text>

        <text 
          class="key-item key-item-special key-item-del" 
          @click="pressBackspace">
          Del
        </text>
      </div>

      <div class="keyboard-row">
        <text 
          class="key-item key-item-special key-item-ctrl" 
          @click="toggleNum">
          {{numFlag ? 'ABC' : '?123'}}
        </text>

        <text 
          class="key-item key-item-space" 
          @click="pressSpace">
          Space
        </text>
      </div>

    </div>
  </div>
</template>

<script>
import vibrator from "@system.vibrator";

export default {
  props: {
    hide: {
      default: true,
    },
    keyboardtype: {
      default: "QWERTY",
    },
    maxlength: {
      default: 5,
    },
    vibratemode: {
      default: "short",
    },
    screentype: {
      default: "rect",
    },
  },
  
  data: {
    upperFlag: false,
    numFlag: false,
    symPageFlag: false,

    activeRow1: [],
    activeRow2: [],
    activeRow3: [],

    row1_lower: ["q", "w", "e", "r", "t", "y", "u", "i", "o", "p"],
    row1_upper: ["Q", "W", "E", "R", "T", "Y", "U", "I", "O", "P"],
    row2_lower: ["a", "s", "d", "f", "g", "h", "j", "k", "l"],
    row2_upper: ["A", "S", "D", "F", "G", "H", "J", "K", "L"],
    row3_lower: ["z", "x", "c", "v", "b", "n", "m"],
    row3_upper: ["Z", "X", "C", "V", "B", "N", "M"],

    row1_num: ["1", "2", "3", "4", "5", "6", "7", "8", "9", "0"],
    row2_num: ["-", "/", ":", ";", "(", ")", "$", "&", "@", "\""],
    row3_num_p1: [".", ",", "?", "!", "'", "_", "-"],
    row3_num_p2: ["[", "]", "{", "}", "#", "%", "^"]
  },

  onInit() {
    this.updateKeyboardLayout();
  },

  updateKeyboardLayout() {
    if (this.numFlag) {
      this.activeRow1 = this.row1_num;
      this.activeRow2 = this.row2_num;
      this.activeRow3 = this.symPageFlag ? this.row3_num_p2 : this.row3_num_p1;
    } else {
      if (this.upperFlag) {
        this.activeRow1 = this.row1_upper;
        this.activeRow2 = this.row2_upper;
        this.activeRow3 = this.row3_upper;
      } else {
        this.activeRow1 = this.row1_lower;
        this.activeRow2 = this.row2_lower;
        this.activeRow3 = this.row3_lower;
      }
    }
  },

  pressKey(char) {
    this.onVibrate();
    this.$emit("key-down", { content: char });
    this.$emit("complete", { content: char });
  },

  pressSpace() {
    this.onVibrate();
    this.$emit("key-down", { content: " " });
    this.$emit("complete", { content: " " });
  },

  pressBackspace() {
    this.onVibrate();
    this.$emit("delete", {});
  },

  toggleShift() {
    this.onVibrate();
    this.upperFlag = !this.upperFlag;
    this.updateKeyboardLayout();
  },

  toggleNum() {
    this.onVibrate();
    this.numFlag = !this.numFlag;
    this.symPageFlag = false;
    this.updateKeyboardLayout();
  },

  toggleSymbolPage() {
    this.onVibrate();
    this.symPageFlag = !this.symPageFlag;
    this.updateKeyboardLayout();
  },

  onVibrate() {
    if (this.vibratemode && this.vibratemode !== "") {
      try {
        vibrator.vibrate({ mode: this.vibratemode });
      } catch (err) {
        console.log("Vibration feedback error: " + err.message);
      }
    }
  }
};
</script>

<style>
/* 240px Absolute Container [cite: 23] */
.keyboard-page {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  overflow: hidden;
}

/* Base layout settings [cite: 24, 25] */
.keyboard-container {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  width: 100%;
  height: 100%;
  background-color: #08090b;
  border-top: 1px solid #1f2228;
  padding: 5px 4px 7px 4px;
  box-sizing: border-box;
}

/* Individual Row Sizing [cite: 26] */
.keyboard-row {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  width: 100%;
  flex: 1;
  min-height: 0;
}

/* Key Styling [cite: 27, 28] */
.key-item {
  flex: 1;
  background-color: #1f232b;
  color: #f7f9ff;
  font-size: 19px;
  font-weight: 600;
  text-align: center;
  line-height: 42px;
  height: 42px;
  margin: 0px 2px;
  border-radius: 8px;
  border: 1px solid #2e3340;
}

/* Special button defaults [cite: 29] */
.key-item-special {
  flex: 1.5;
  background-color: #141820;
  color: #d9e0ee;
  font-size: 15px;
  font-weight: 600;
}

/* Blue shift color for inactive, bright highlighted blue for active [cite: 30] */
.key-item-shift {
  background-color: #11263f;
  color: #67b1ff;
  border: 1px solid #234d7d;
}
.key-item-shift-active {
  background-color: #0a84ff;
  color: #ffffff;
  border: 1px solid #4ea5ff;
}

/* Warning crimson background for the delete action */
.key-item-del {
  background-color: #3a1a23;
  color: #ff6372;
  border: 1px solid #6e2a36;
}

/* Highlighted Symbol Pages toggle */
.key-item-sympage {
  background-color: #221938;
  color: #c09bff;
  border: 1px solid #4a3576;
}

/* Quick Toggle control (?123 / ABC) [cite: 31] */
.key-item-ctrl {
  flex: 2.5;
  color: #72b7ff;
  font-size: 16px;
}

/* Spacebar [cite: 32] */
.key-item-space {
  flex: 7.5;
  background-color: #1b2028;
  color: #a7afbf;
  font-size: 16px;
  border-color: #2c3340;
}

.row2-spacer {
  flex: 0.45;
}

.keyboard-page-rect {
  height: 236px;
}

.keyboard-container-rect {
  padding-left: 4px;
  padding-right: 4px;
}

.keyboard-page-round {
  height: 224px;
}

.keyboard-container-round {
  padding-left: 16px;
  padding-right: 16px;
}
</style>